# Copy to .env and fill in your values. Used by both local dev and Docker.
# For Docker, DB_HOST and REDIS_URL are set in docker-compose.yml; these apply when running backend locally.

# MySQL (Docker sets DB_HOST=mysql, REDIS_URL for you)
# DB_HOST=localhost
# DB_PASSWORD=password

# Redis
# REDIS_URL=redis://localhost:6379/0

# Elastic / Kibana
KIBANA_URL=https://YOUR-DEPLOYMENT.kb.us-east-1.aws.elastic.cloud
KIBANA_API_KEY=
COMMANDER_AGENT_ID=
SCANNER_AGENT_ID=
TRACER_AGENT_ID=
ADVOCATE_AGENT_ID=

# Slack
SLACK_BOT_TOKEN=
SLACK_CHANNEL=#security-ops

# App (Docker sets these; override if needed)
# NIGHTWATCH_DASHBOARD_URL=http://localhost:8080
# FRONTEND_URL=http://localhost:8080
